# TalentTrust AI backend — environment template. Copy to .env and fill secrets.
# No real secret is ever committed.

# --- General ---
APP_NAME=TalentTrust AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- Database / cache ---
DATABASE_URL=postgresql+asyncpg://talenttrust:talenttrust@localhost:5432/talenttrust
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- Providers (LLM / embeddings). Default mock = fully offline, deterministic. ---
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
EMBEDDING_DIM=384
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- CV / candidate data (used from Phase 4 onward) ---
MAX_CV_SIZE_BYTES=5242880
CANDIDATE_DATA_TTL_DAYS=180

# --- Async jobs ---
ANALYSIS_EAGER=false

# --- Seed (initial org + recruiter created on startup if absent) ---
SEED_ORG_NAME=Demo Org
SEED_USER_EMAIL=recruiter@demo.com
SEED_USER_PASSWORD=changeme-please-123

# --- Security / HTTP ---
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
